{
  "app_name": "AttendanceApp",
  "app_type": "attendance tracking app",
  "summary": "To efficiently track and manage attendance for a group of users or employees.",
  "target_users": [
    "Employees",
    "Students",
    "Managers",
    "Teachers"
  ],
  "top_features": [
    "User Registration",
    "User Login",
    "Password Reset",
    "User Profile Management",
    "Manual Check-in/Check-out",
    "Location-based Check-in/Check-out",
    "Current Attendance Status Display",
    "Daily Attendance Log View",
    "Monthly Attendance Summary View",
    "Export Daily Attendance Log Report"
  ],
  "main_screens": [
    "SplashScreen",
    "OnboardingScreen",
    "LoginScreen",
    "SignupScreen",
    "PasswordResetScreen",
    "EmployeeDashboardScreen",
    "UserProfileScreen",
    "EditUserProfileScreen",
    "DailyAttendanceLogScreen",
    "MonthlyAttendanceSummaryScreen",
    "SettingsScreen",
    "PersonalAttendanceRulesScreen"
  ],

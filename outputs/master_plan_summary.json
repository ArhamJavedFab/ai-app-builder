    "pattern": "feature_first_clean_architecture",
    "navigation": "go_router"
  },
  "design": {
    "theme": "modern_minimal",
    "primary_color": "#ffffff",
    "background_color": "#FFFFFF",
    "fonts": [
      "Montserrat",
      "Lato"
    ]
  },
  "quality": {
    "validation_passed": true,
    "confidence": 1.0,
    "warnings": [
